{
  "name": "tannur",
  "version": "0.2.0",
  "description": "Official SDK for the Tannur Event-Sourced BaaS platform",
  "keywords": ["event-sourcing", "baas", "backend", "events", "projections", "hash-chain"],
  "homepage": "https://github.com/Z10N-exe/tannur#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Z10N-exe/tannur.git",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "author": "Z10N-exe",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --bundle",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
