{
  "name": "@tannur/sveltekit",
  "version": "0.1.0",
  "description": "SvelteKit SDK for Tannur Event-Sourced BaaS with stores and SSR support",
  "keywords": ["tannur", "event-sourcing", "baas", "svelte", "sveltekit", "stores", "typescript"],
  "homepage": "https://github.com/Z10N-exe/tannur#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Z10N-exe/tannur.git",
    "directory": "packages/sveltekit-sdk"
  },
  "license": "MIT",
  "author": "Z10N-exe",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "svelte": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --bundle",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@tannur/shared": "*",
    "tannur-universal": "*"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "@testing-library/svelte": "^4.0.0",
    "@types/node": "^20.0.0",
    "svelte": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "*",
    "vitest": "*"
  },
  "peerDependencies": {
    "svelte": ">=4.0.0",
    "@sveltejs/kit": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}